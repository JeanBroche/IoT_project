/home/admin/IoT_project

[Unit]
Description=Lance le script de lecture des données des ports série
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/IoT_project
ExecStart=/bin/bash -c "source /home/admin/IoT_project/IoT_venv/bin/activate && exec python -m raspberry_scripts.serial_data_reading"
Restart=on-failure

[Install]
WantedBy=multi-user.target
